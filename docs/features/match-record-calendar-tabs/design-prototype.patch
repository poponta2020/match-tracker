+// DESIGN-PROTO: プレビュー専用ルート（実装時に削除。/matches のタブコンテナへ統合する）。
+// バックエンド・ログイン不要で MatchViewTabs + MatchCalendar の見た目を確認するための足場。
+import { useState } from 'react';
+import MatchViewTabs from './matches/MatchViewTabs';
+import MatchCalendar from './matches/MatchCalendar';
+
+const SELF_ID = 1;
+
+// DESIGN-PROTO: スタブ試合データ（実装時は GET /matches/player/{selfId} のレスポンスで置換）。
+// 複数試合ある日 / 空の日 / 長いメモ / 指導 / ゲスト / 複数会場 の各ケースを再現する。
+const buildStubMatches = () => {
+  const t = new Date();
+  const y = t.getFullYear();
+  const mo = t.getMonth();
+  const d = (day) => `${y}-${String(mo + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
+  const td = t.getDate();
+  const base = { player1Id: SELF_ID };
+  return [
+    // 今日: 3試合（負け×2＝長いメモ、勝ち1）
+    { ...base, id: 101, matchDate: d(td), matchNumber: 1, result: '負け', scoreDifference: 13,
+      opponentName: 'ざきお', player2KyuRank: 'A級', myOtetsukiCount: 1, venueName: '土居家',
+      myPersonalNotes: 'in土居家。後半粘っただけの試合。敵陣で抜いた札が全て別れ札。逆に言えば敵陣の別れはしっかり取れているということか。' },
+    { ...base, id: 102, matchDate: d(td), matchNumber: 2, result: '負け', scoreDifference: 13,
+      opponentName: 'ざきお', player2KyuRank: 'A級', myOtetsukiCount: 3, venueName: '土居家',
+      myPersonalNotes: '序盤有利な感じだったのにお手だったり拾われたりで物凄い差をつけられた。たれをかものお手とさびしさ。' },
+    { ...base, id: 103, matchDate: d(td), matchNumber: 3, result: '勝ち', scoreDifference: 7,
+      opponentName: 'たなか', player2KyuRank: 'B級', myOtetsukiCount: 0, venueName: '土居家',
+      myPersonalNotes: '' },
+    // 単発の日
+    { ...base, id: 104, matchDate: d(3), matchNumber: 1, result: '勝ち', scoreDifference: 5,
+      opponentName: 'やまだ', player2KyuRank: 'C級', myOtetsukiCount: 2, venueName: 'クラ館' },
+    { ...base, id: 105, matchDate: d(7), matchNumber: 1, result: '負け', scoreDifference: 2,
+      opponentName: 'さとう', player2KyuRank: 'A級', myOtetsukiCount: 1, venueName: 'クラ館' },
+    // 指導試合
+    { ...base, id: 106, matchDate: d(12), matchNumber: 2, isLesson: true,
+      opponentName: 'こばやし', player2KyuRank: 'D級', venueName: 'クラ館', myPersonalNotes: '指導試合。' },
+    // ゲスト（相手級なし・お手つき不明）
+    { ...base, id: 107, matchDate: d(18), matchNumber: 1, result: '勝ち', scoreDifference: 20,
+      opponentName: 'ゲスト選手', player2KyuRank: null, myOtetsukiCount: null, venueName: '東区民' },
+    // 複数試合の日（会場は日付に一意 → 連番・同一会場）
+    { ...base, id: 108, matchDate: d(22), matchNumber: 1, result: '勝ち', scoreDifference: 8,
+      opponentName: 'いとう', player2KyuRank: 'B級', myOtetsukiCount: 0, venueName: 'クラ館' },
+    { ...base, id: 109, matchDate: d(22), matchNumber: 2, result: '負け', scoreDifference: 4,
+      opponentName: 'すずき', player2KyuRank: 'A級', myOtetsukiCount: 2, venueName: 'クラ館' },
+  ];
+};
+
+const DesignCalendarPreview = () => {
+  const [view, setView] = useState('calendar');
+  const matches = buildStubMatches();
+
+  return (
+    <div className="min-h-screen bg-white">
+      {/* 緑トップバー（カレンダータブ = 自分の名前＋級） */}
+      <div className="bg-[#4a6b5a] px-4 py-3">
+        <h1 className="text-xl font-bold text-white flex items-baseline gap-2">
+          {/* DESIGN-PROTO: 実装時は currentPlayer.name / kyuRank */}
+          <span>山田太郎</span>
+          <span className="text-sm font-normal text-white/70">A級</span>
+        </h1>
+      </div>
+
+      {/* タブ帯 */}
+      <MatchViewTabs active={view} onChange={setView} />
+
+      {/* 本文 */}
+      {view === 'calendar' ? (
+        <MatchCalendar matches={matches} selfId={SELF_ID} />
+      ) : (
+        <div className="p-8 text-center text-gray-500">
+          （戦績確認タブ = 既存 MatchList。本プレビューでは省略）
+        </div>
+      )}
+    </div>
+  );
+};
+
+export default DesignCalendarPreview;
diff --git a/karuta-tracker-ui/src/pages/matches/MatchCalendar.jsx b/karuta-tracker-ui/src/pages/matches/MatchCalendar.jsx
new file mode 100644
index 00000000..7c98842f
--- /dev/null
+++ b/karuta-tracker-ui/src/pages/matches/MatchCalendar.jsx
@@ -0,0 +1,236 @@
+import { useMemo, useState } from 'react';
+import { useNavigate } from 'react-router-dom';
+import { ChevronLeft, ChevronRight, ChevronDown } from 'lucide-react';
+import YearMonthPicker from '../../components/YearMonthPicker';
+
+/**
+ * 戦績確認画面「カレンダー」タブの本体。
+ * 常に自分（selfId）の試合を月カレンダーで俯瞰し、日を選ぶとその日の試合
+ * （勝敗・相手・お手つき・個人メモ）を確認して試合詳細へ遷移する。
+ *
+ * matches: 自分視点の MatchDto 配列（GET /matches/player/{selfId} 相当）
+ * selfId : ログインユーザーの player id（相手の級・相手名の算出に使う）
+ */
+const WEEKDAYS = ['日', '月', '火', '水', '木', '金', '土'];
+
+const iso = (y, m0, d) =>
+  `${y}-${String(m0 + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
+
+const MatchCalendar = ({ matches = [], selfId }) => {
+  const navigate = useNavigate();
+  const today = new Date();
+  const todayIso = iso(today.getFullYear(), today.getMonth(), today.getDate());
+
+  const [viewYear, setViewYear] = useState(today.getFullYear());
+  const [viewMonth, setViewMonth] = useState(today.getMonth()); // 0-based
+  const [selectedDate, setSelectedDate] = useState(todayIso);
+  const [showPicker, setShowPicker] = useState(false);
+
+  // 日付 -> その日の試合（試合番号昇順）
+  const matchesByDate = useMemo(() => {
+    const map = {};
+    for (const m of matches) {
+      if (!m.matchDate) continue;
+      (map[m.matchDate] ||= []).push(m);
+    }
+    for (const k of Object.keys(map)) {
+      map[k].sort((a, b) => (a.matchNumber ?? 0) - (b.matchNumber ?? 0));
+    }
+    return map;
+  }, [matches]);
+
+  // 表示中の月の総試合数（月ラベル下のバッジ）
+  const monthTotal = useMemo(
+    () =>
+      matches.filter((m) => {
+        if (!m.matchDate) return false;
+        const [y, mo] = m.matchDate.split('-').map(Number);
+        return y === viewYear && mo === viewMonth + 1;
+      }).length,
+    [matches, viewYear, viewMonth]
+  );
+
+  // カレンダーグリッド（前月・翌月のはみ出しセルを含む）
+  const weeks = useMemo(() => {
+    const startDow = new Date(viewYear, viewMonth, 1).getDay();
+    const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();
+    const prevMonthDays = new Date(viewYear, viewMonth, 0).getDate();
+    const cells = [];
+    for (let i = 0; i < startDow; i++) {
+      cells.push({ day: prevMonthDays - startDow + 1 + i, inMonth: false });
+    }
+    for (let d = 1; d <= daysInMonth; d++) {
+      cells.push({ day: d, inMonth: true, date: iso(viewYear, viewMonth, d) });
+    }
+    let nextDay = 1;
+    while (cells.length % 7 !== 0) {
+      cells.push({ day: nextDay++, inMonth: false });
+    }
+    const w = [];
+    for (let i = 0; i < cells.length; i += 7) w.push(cells.slice(i, i + 7));
+    return w;
+  }, [viewYear, viewMonth]);
+
+  const changeMonth = (delta) => {
+    const nd = new Date(viewYear, viewMonth + delta, 1);
+    setViewYear(nd.getFullYear());
+    setViewMonth(nd.getMonth());
+  };
+
+  const selectedMatches = matchesByDate[selectedDate] || [];
+  // 会場は日付に対し一意 → 見出しに1回だけ表示する
+  const selectedVenue = selectedMatches.find((m) => m.venueName)?.venueName || '';
+  const [, selMonth, selDay] = selectedDate.split('-').map(Number);
+
+  const resultSymbol = (m) => (m.result === '勝ち' ? '〇' : m.result === '負け' ? '×' : '△');
+  const resultColor = (m) =>
+    m.result === '勝ち' ? 'text-green-600' : m.result === '負け' ? 'text-red-600' : 'text-gray-600';
+  const opponentRank = (m) => (m.player1Id === selfId ? m.player2KyuRank : m.player1KyuRank);
+
+  const weekdayColor = (dow) => (dow === 0 ? 'text-red-500' : dow === 6 ? 'text-blue-500' : 'text-[#374151]');
+
+  return (
+    <div className="pb-24">
+      {/* 月送りナビ（月ラベル押下で年月ピッカー・下に月間試合数バッジ） */}
+      <div className="relative px-4 py-3">
+        <div className="flex items-center justify-between">
+          <button onClick={() => changeMonth(-1)} className="p-2 text-[#4a6b5a]" aria-label="前の月">
+            <ChevronLeft className="w-5 h-5" />
+          </button>
+          <button
+            type="button"
+            onClick={() => setShowPicker((v) => !v)}
+            className="flex flex-col items-center px-3 py-1 rounded-lg hover:bg-[#eef2ef] transition-colors"
+          >
+            <span className="flex items-center gap-1 text-lg font-bold text-[#374151]">
+              {viewYear}年{viewMonth + 1}月
+              <ChevronDown className="w-4 h-4 text-[#6b7280]" aria-hidden="true" />
+            </span>
+            <span className="mt-0.5 text-xs font-semibold text-[#4a6b5a] bg-[#eef2ef] rounded-full px-2 py-0.5">
+              {monthTotal}試合
+            </span>
+          </button>
+          <button onClick={() => changeMonth(1)} className="p-2 text-[#4a6b5a]" aria-label="次の月">
+            <ChevronRight className="w-5 h-5" />
+          </button>
+        </div>
+        {showPicker && (
+          <YearMonthPicker
+            currentYear={viewYear}
+            currentMonth={viewMonth + 1}
+            onSelect={(y, m) => {
+              setViewYear(y);
+              setViewMonth(m - 1);
+            }}
+            onClose={() => setShowPicker(false)}
+          />
+        )}
+      </div>
+
+      {/* 曜日ヘッダ */}
+      <div className="grid grid-cols-7 px-2">
+        {WEEKDAYS.map((w, i) => (
+          <div
+            key={w}
+            className={`text-center text-sm py-1 ${
+              i === 0 ? 'text-red-500' : i === 6 ? 'text-blue-500' : 'text-[#6b7280]'
+            }`}
+          >
+            {w}
+          </div>
+        ))}
+      </div>
+
+      {/* 日セル */}
+      <div className="px-2">
+        {weeks.map((week, wi) => (
+          <div key={wi} className="grid grid-cols-7 gap-0.5">
+            {week.map((cell, ci) => {
+              if (!cell.inMonth) {
+                return (
+                  <div
+                    key={ci}
+                    className="h-14 flex items-start justify-center pt-1.5 text-sm text-gray-300 select-none"
+                  >
+                    {cell.day}
+                  </div>
+                );
+              }
+              const count = (matchesByDate[cell.date] || []).length;
+              const isToday = cell.date === todayIso;
+              const isSelected = cell.date === selectedDate;
+              let numCls = 'w-7 h-7 flex items-center justify-center rounded-full text-sm ';
+              if (isToday) numCls += 'border border-[#4a6b5a] text-[#4a6b5a] font-bold';
+              else if (isSelected) numCls += 'text-[#374151] font-bold';
+              else numCls += weekdayColor(ci);
+              return (
+                <button
+                  key={ci}
+                  type="button"
+                  onClick={() => setSelectedDate(cell.date)}
+                  className={`h-14 rounded-lg border-2 flex flex-col items-center pt-1.5 transition-colors ${
+                    isSelected ? 'border-[#4a6b5a] bg-[#eef2ef]' : 'border-transparent hover:bg-[#f4f7f5]'
+                  }`}
+                >
+                  <span className={numCls}>{cell.day}</span>
+                  {count > 0 && (
+                    <span className="mt-0.5 min-w-[1.15rem] h-[1.15rem] px-1 flex items-center justify-center rounded-full bg-[#4a6b5a] text-white text-[0.65rem] font-bold leading-none">
+                      {count}
+                    </span>
+                  )}
+                </button>
+              );
+            })}
+          </div>
+        ))}
+      </div>
+
+      {/* 選択日の見出し帯（M/D 会場名。会場は日付に一意） */}
+      <div className="mt-3 bg-[#4a6b5a] text-white px-4 py-2 font-bold">
+        {selMonth}/{selDay}
+        {selectedVenue ? `　${selectedVenue}` : ''}
+      </div>
+
+      {/* 選択日の試合リスト */}
+      {selectedMatches.length === 0 ? (
+        <div className="bg-[#f9f6f2] py-16 text-center text-gray-500">記録がありません</div>
+      ) : (
+        <div className="bg-[#f9f6f2] divide-y divide-[#e5e0da]">
+          {selectedMatches.map((m) => (
+            <button
+              key={m.id}
+              type="button"
+              onClick={() => navigate(`/matches/${m.id}`)}
+              className="w-full text-left px-4 py-3 hover:bg-[#f2ede5] transition-colors"
+            >
+              <div className="flex items-baseline gap-1.5 flex-wrap text-sm">
+                <span className="text-[#374151]">{m.matchNumber}試合目：</span>
+                {m.isLesson ? (
+                  <span className="font-bold text-gray-500">指導</span>
+                ) : (
+                  <span className={`font-bold ${resultColor(m)}`}>
+                    {resultSymbol(m)}{m.scoreDifference}
+                  </span>
+                )}
+                <span className="font-medium text-[#374151]">
+                  {m.opponentName}
+                  {opponentRank(m) ? `（${opponentRank(m).replace('級', '')}）` : ''}
+                </span>
+                {m.myOtetsukiCount != null && (
+                  <span className="text-[#6b7280]">お手{m.myOtetsukiCount}</span>
+                )}
+              </div>
+              {m.myPersonalNotes && (
+                <div className="text-sm text-[#6b7280] mt-0.5 whitespace-pre-wrap break-words">
+                  {m.myPersonalNotes}
+                </div>
+              )}
+            </button>
+          ))}
+        </div>
+      )}
+    </div>
+  );
+};
+
+export default MatchCalendar;
diff --git a/karuta-tracker-ui/src/pages/matches/MatchViewTabs.jsx b/karuta-tracker-ui/src/pages/matches/MatchViewTabs.jsx
