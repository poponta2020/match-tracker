+// DESIGN-PROTO: ボトムナビ リキッドグラス化の見た目確認専用ページ。productionize 時に削除する。
+// 認証・バックエンド不要で、実 Layout のボトムナビをモック本文の上に重ねて確認する。
+import Layout from '../components/Layout';
+
+const swatches = [
+  '#8fb3c9', '#e6b89c', '#a7c4a0', '#c9a7c4', '#d6c98f',
+  '#9cb0e6', '#e69ca8', '#8fc9bf', '#c9b98f', '#b0a7e6',
+];
+
+const DesignGlassNavPreview = () => {
+  return (
+    <Layout>
+      <div className="space-y-3">
+        <p className="text-sm text-[#4a6b5a]">
+          DESIGN-PROTO プレビュー: 下のガラスピルの背後をスクロールして透け・ぼけを確認。
+          <br />
+          ?active=/matches のようにクエリでアクティブ項目を切替可。
+        </p>
+
+
+        {swatches.map((c, i) => (
+          <div
+            key={i}
+            className="rounded-xl px-4 py-6 text-white font-semibold shadow-sm"
+            style={{ background: c }}
+          >
+            サンプルカード {i + 1}
+          </div>
+        ))}
+      </div>
+    </Layout>
+  );
+};
+
+export default DesignGlassNavPreview;
